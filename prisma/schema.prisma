generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum Instrument {
  PIANO
  OUD
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  instructor          Instructor?
  enrollments         Enrollment[]
  reviews             Review[]
  progress            Progress[]
  accounts            Account[]
  sessions            Session[]
  sentMessages        Message[]            @relation("SentMessages")
  studentMeetings     Meeting[]            @relation("StudentMeetings")
  instructorMeetings  Meeting[]            @relation("InstructorMeetings")
  receivedMessages    Message[]            @relation("ReceivedMessages")
  homeworkSubmissions HomeworkSubmission[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Instructor {
  id           String     @id @default(cuid())
  userId       String     @unique
  bio_en       String     @db.Text
  bio_ar       String     @db.Text
  instrument   Instrument
  experience   Int
  rating       Float      @default(0)
  totalReviews Int        @default(0)
  isVerified   Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses Course[]
}

model Course {
  id             String     @id @default(cuid())
  title_en       String
  title_ar       String
  description_en String     @db.Text
  description_ar String     @db.Text
  slug           String     @unique
  thumbnail      String
  instrument     Instrument
  level          Level
  price          Float      @default(0)
  isPublished    Boolean    @default(false)
  isFeatured     Boolean    @default(false)
  totalStudents  Int        @default(0)
  rating         Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  instructorId String
  instructor   Instructor   @relation(fields: [instructorId], references: [id])
  sections     Section[]
  enrollments  Enrollment[]
  reviews      Review[]

  @@index([slug])
  @@index([instrument, isPublished])
}

model Section {
  id       String @id @default(cuid())
  title_en String
  title_ar String
  order    Int
  courseId String

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id        String   @id @default(cuid())
  title_en  String
  title_ar  String
  videoUrl  String
  duration  Int      @default(0)
  order     Int
  isFree    Boolean  @default(false)
  sectionId String
  createdAt DateTime @default(now())

  section  Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@index([sectionId])
}

model Enrollment {
  id         String           @id @default(cuid())
  userId     String
  courseId   String
  status     EnrollmentStatus @default(ACTIVE)
  paidAmount Float            @default(0)
  enrolledAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model Progress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  completed      Boolean  @default(false)
  watchedSeconds Int      @default(0)
  updatedAt      DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String   @db.Text
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
}

model Homework {
  id           String    @id @default(cuid())
  title        String
  description  String?   @db.Text
  courseSlug   String
  instructorId String
  dueDate      DateTime?
  createdAt    DateTime  @default(now())

  submissions HomeworkSubmission[]

  @@index([courseSlug])
}

model HomeworkSubmission {
  id          String   @id @default(cuid())
  studentId   String
  homeworkId  String
  answer      String   @db.Text
  grade       String?
  feedback    String?  @db.Text
  submittedAt DateTime @default(now())

  student  User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)

  @@unique([studentId, homeworkId])
}

model Meeting {
  id          String   @id @default(cuid())
  instructorId String
  studentId   String
  platform    String
  link        String
  date        String
  time        String
  note        String?
  createdAt   DateTime @default(now())

  student    User @relation("StudentMeetings",    fields:[studentId],    references:[id], onDelete:Cascade)
  instructor User @relation("InstructorMeetings", fields:[instructorId], references:[id], onDelete:Cascade)

  @@index([instructorId])
  @@index([studentId])
}

model PasswordResetCode {
  id        String   @id @default(cuid())
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
